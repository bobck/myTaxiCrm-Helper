generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/client-remonline"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_REMONLINE")
  schemas  = ["public", "private_api"]
  relationMode = "prisma"
}

model Posting {
  id             Int              @id
  idLabel        String           @map("id_label")
  createdAt      BigInt           @map("created_at")
  createdById    Int              @map("created_by_id")
  supplierId     Int              @map("supplier_id")
  warehouseId    Int              @map("warehouse_id")
  description    String?
  documentNumber String?          @map("document_number")
  products       PostingProduct[]
  privateDetails PrivateApiPostingProducts[] 
  isFailedToScrape Boolean @default(false) @map("is_failed_to_scrape")
  @@map("postings")
  @@schema("public")
}

model PostingProduct {
  id           Int
  postingId    Int     @map("posting_id")
  title        String
  uomId        Int     @map("uom_id")
  code         String?
  article      String?
  amount       Float
  price        Float
  isSerial     Boolean @map("is_serial")
  sernums      Json?
  serialNumber String  @default("") @map("serial_number")
  posting      Posting @relation(fields: [postingId], references: [id])
  product      Product? @relation(fields: [id], references: [id], onUpdate: Restrict, onDelete: Restrict)

  @@id([id, postingId, serialNumber])
  @@map("posting_products")
  @@schema("public")
}

model PrivateApiPostingProducts {
  postingId                  Int      @map("posting_id")
  postingItemId              Int      @map("posting_item_id")
  productId                  Int      @map("product_id")
  cellId                     Int      @map("cell_id")
  cellTitle                  String?  @map("cell_title")
  warehouseId                Int?     @map("warehouse_id")
  code                       String?
  article                    String?
  title                      String?
  uomId                      Int?     @map("uom_id")
  quantity                   Float?
  cost                       Float?
  totalCost                  Float?   @map("total_cost")
  snAccounting               Boolean? @map("sn_accounting")
  sernumsJson                String?  @map("sernums_json")
  warranty                   Int?
  warrantyPeriod             Int?     @map("warranty_period")
  isCustomTaxes              Boolean? @map("is_custom_taxes")
  taxesJson                  String?  @map("taxes_json")
  isEnableExpirationTracking Boolean? @map("is_enable_expiration_tracking")
  isExpiringSoonAlertEnabled Boolean? @map("is_expiring_soon_alert_enabled")
  isCriticalAlertEnabled     Boolean? @map("is_critical_alert_enabled")
  expiringSoonAlertValue     Int?     @map("expiring_soon_alert_value")
  criticalAlertValue         Int?     @map("critical_alert_value")
  expiringSoonAlertUnit      Int?     @map("expiring_soon_alert_unit")
  criticalAlertUnit          Int?     @map("critical_alert_unit")

  serialNumber String @default("") @map("serial_number")
  posting      Posting  @relation(fields: [postingId], references: [id])
  @@id([postingId, postingItemId, serialNumber])
  @@map("posting_products")
  @@schema("private_api")
}

model Cashbox {
  id                       Int      @id
  title                    String?
  type                     Int?
  currencyName             String?  @map("currency_name")
  currencyCode             String?  @map("currency_code")
  balance                  Float?
  isGlobal                 Boolean? @map("is_global")
  isEnabled                Boolean  @default(true) @map("is_enabled")
  lastTransactionCreatedAt BigInt?  @map("last_transaction_created_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  transactions             CashboxTransaction[]

  @@map("cashboxes")
  @@schema("public")
}

model CashboxTransaction {
  id                    Int      @id
  cashboxId             Int      @map("cashbox_id")
  value                 Float
  direction             Int
  employeeId            Int?     @map("employee_id")
  createdAt             BigInt   @map("created_at")
  description           String?
  clientId              Int?     @map("client_id")
  relatedDocumentId     Int?     @map("related_document_id")
  relatedDocumentType   Int?     @map("related_document_type")
  cashflowItemId        Int?     @map("cashflow_item_id")
  cashflowItemName      String?  @map("cashflow_item_name")
  cashflowItemDirection Int?     @map("cashflow_item_direction")
  cashbox               Cashbox  @relation(fields: [cashboxId], references: [id])

  @@index([cashboxId, createdAt])
  @@map("cashbox_transactions")
  @@schema("public")
}

model Refund {
  id                  Int      @id
  number              String
  branchId            Int      @map("branch_id")
  createdAt           DateTime @map("created_at")
  createdById         Int      @map("created_by_id")
  clientId            Int?     @map("client_id")
  clientName          String?  @map("client_name")
  comment             String?
  relatedDocumentId   Int?     @map("related_document_id")
  relatedDocumentType String?  @map("related_document_type")
  total               Float

  @@map("refunds")
  @@schema("public")
}

model Product {
  id                             Int      @id
  code                           String?
  title                          String
  isSerial                       Boolean  @default(false) @map("is_serial")
  article                        String?
  description                    String?
  isEnableExpirationTracking     Boolean? @map("is_enable_expiration_tracking")
  isExpirationTrackingEnabled    Boolean? @map("is_expiration_tracking_enabled")
  isExpiringSoonAlertEnabled     Boolean? @map("is_expiring_soon_alert_enabled")
  isCriticalAlertEnabled         Boolean? @map("is_critical_alert_enabled")
  defaultSupplierId              Int?     @map("default_supplier_id")
  categoryId                     Int?     @map("category_id")
  categoryTitle                  String?  @map("category_title")
  uomId                          Int?     @map("uom_id")
  warranty                       Int?
  warrantyPeriod                 Int?     @map("warranty_period")
  prices                         Json?
  images                         Json?
  customFields                   Json?    @map("custom_fields")
  isDimensionsWeightEnabled      Boolean? @map("is_dimensions_weight_enabled")

  postingProducts                PostingProduct[]

  @@map("products")
  @@schema("public")
}

model Uom {
  id          Int      @id
  description String?
  title       String?
  uomType     String?  @map("uom_type")
  isImperial  Boolean? @map("is_imperial")
  isSystem    Boolean? @map("is_system")
  entityTypes String[] @map("entity_types")

  @@map("uoms")
  @@schema("public")
}

model Employee {
  id          Int     @id
  email       String?
  firstName   String? @map("first_name")
  lastName    String? @map("last_name")
  notes       String?
  phone       String?
  deleted     Boolean
  position    String?
  createdAt   BigInt  @map("created_at")
  startedWork BigInt  @map("started_work")
  avatar      String?

  @@map("employees")
  @@schema("public")
}

model EntitySync {
  entityName  String   @id @map("entity_name")
  syncDetails Json     @map("sync_details")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("entity_sync")
  @@schema("public")
}

model Asset {
  id           Int     @id
  uid          String
  title        String?
  color        String?
  state        String?
  cost         Int?
  group        String?
  brand        String?
  model        String?
  modification String?
  description  String?
  year         String?
  regNumber    String  @map("reg_number")
  ownerName    String? @map("owner_name")
  warehouse    Json
  address      String?
  image        String?
  customFields Json    @map("custom_fields")

  @@map("assets")
  @@schema("public")
}

model Order {
  id                   Int       @id
  number               String?
  statusId             Int?      @map("status_id")
  statusName           String?   @map("status_name")
  statusOverdue        Boolean?  @map("status_overdue")
  createdAt            DateTime? @map("created_at")
  createdById          Int?      @map("created_by_id")
  modifiedAt           DateTime? @map("modified_at")
  doneAt               DateTime? @map("done_at")
  closedAt             DateTime? @map("closed_at")
  closedById           Int?      @map("closed_by_id")
  branchId             Int?      @map("branch_id")
  orderTypeId          Int?      @map("order_type_id")
  orderTypeName        String?   @map("order_type_name")
  managerId            Int?      @map("manager_id")
  assigneeId           Int?      @map("assignee_id")
  assetId              Int?      @map("asset_id")
  assetUid             String?   @map("asset_uid")
  assetBrand           String?   @map("asset_brand")
  assetModel           String?   @map("asset_model")
  assetYear            String?   @map("asset_year")
  clientId             Int?      @map("client_id")
  clientName           String?   @map("client_name")
  clientIsOrganization Boolean?  @map("client_is_organization")
  payerId              Int?      @map("payer_id")
  payerName            String?   @map("payer_name")
  scheduledFor         DateTime? @map("scheduled_for")
  scheduledTo          DateTime? @map("scheduled_to")
  resourceId           Int?      @map("resource_id")
  resourceName         String?   @map("resource_name")
  malfunction          String?
  managerNotes         String?   @map("manager_notes")
  engineerNotes        String?   @map("engineer_notes")
  address              String?
  resume               String?
  estimatedPrice       Float?    @map("estimated_price")
  dueDate              DateTime? @map("due_date")
  overdue              Boolean?
  discountSum          Float?    @map("discount_sum")
  payed                Float?
  total                Float?
  warrantyDate         DateTime? @map("warranty_date")
  urgent               Boolean?
  isDeductionRequired  Boolean?  @map("is_deduction_required")
  adCampaignId         Int?      @map("ad_campaign_id")
  customFields         Json?     @map("custom_fields")
  assetCustomFields    Json?     @map("asset_custom_fields")
  clientCustomFields   Json?     @map("client_custom_fields")

  @@map("orders")
  @@schema("public")
  @@index([modifiedAt])
}

model OrderItem {
  orderId             Int       @map("order_id")
  id                  Int
  createdAt           DateTime? @map("created_at")
  assigneeId          Int?      @map("assignee_id")
  entityId            Int?      @map("entity_id")
  entityType          String?   @map("entity_type")
  entityTitle         String?   @map("entity_title")
  entityCode          String?   @map("entity_code")
  entitySku           String?   @map("entity_sku")
  entityDescription   String?   @map("entity_description")
  entitySnAccounting  Boolean?  @map("entity_sn_accounting")
  entityIsHidden      Boolean?  @map("entity_is_hidden")
  uomId               Int?      @map("uom_id")
  uomTitle            String?   @map("uom_title")
  uomDescription      String?   @map("uom_description")
  quantity            Float?
  price               Float?
  cost                Float?
  marginId            Int?      @map("margin_id")
  isDeductionRequired Boolean?  @map("is_deduction_required")
  isRefunded          Boolean?  @map("is_refunded")
  comment             String?
  commentVisibility   String?      @map("comment_visibility")
  discountType        String?   @map("discount_type")
  discountPercentage  Float?    @map("discount_percentage")
  discountAmount      Float?    @map("discount_amount")
  discountSponsor     String?   @map("discount_sponsor")
  warrantyPeriod      Int?      @map("warranty_period")
  warrantyPeriodUnits String?   @map("warranty_period_units")
  expirationDate      DateTime? @map("expiration_date")
  taxes               Json?
  writeOffs           Json?     @map("write_offs")

  @@id([orderId, id])
  @@map("order_items")
  @@schema("public")
}

model Client {
  id                    Int      @id
  name                  String?
  firstName             String?  @map("first_name")
  lastName              String?  @map("last_name")
  email                 String?
  phone                 Json?
  notes                 String?
  address               String?
  supplier              Boolean?
  juridical             Boolean?
  conflicted            Boolean?
  modifiedAt            BigInt?  @map("modified_at")
  createdAt             BigInt?  @map("created_at")
  discountCode          String?  @map("discount_code")
  discountGoods         Float?   @map("discount_goods")
  orderDiscountServices Float?   @map("order_discount_services")
  saleDiscountServices  Float?   @map("sale_discount_services")
  discountMaterials     Float?   @map("discount_materials")
  customFields          Json?    @map("custom_fields")
  adCampaignId          Int?     @map("ad_campaign_id")

  @@index([modifiedAt])
  @@map("clients")
  @@schema("public")
}