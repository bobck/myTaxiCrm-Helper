generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/client-remonline"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_REMONLINE")
  schemas  = ["public", "private_api"]
  relationMode = "prisma"
}

model Posting {
  id             Int              @id
  idLabel        String           @map("id_label")
  createdAt      BigInt           @map("created_at")
  createdById    Int              @map("created_by_id")
  supplierId     Int              @map("supplier_id")
  warehouseId    Int              @map("warehouse_id")
  description    String?
  documentNumber String?          @map("document_number")
  products       PostingProduct[]
  privateDetails PrivateApiPostingProducts[] 
  isFailedToScrape Boolean @default(false) @map("is_failed_to_scrape")
  @@map("postings")
  @@schema("public")
}

model PostingProduct {
  id           Int
  postingId    Int     @map("posting_id")
  title        String
  uomId        Int     @map("uom_id")
  code         String?
  article      String?
  amount       Float
  price        Float
  isSerial     Boolean @map("is_serial")
  sernums      Json?
  serialNumber String  @default("") @map("serial_number")
  posting      Posting @relation(fields: [postingId], references: [id])
  product      Product? @relation(fields: [id], references: [id], onUpdate: Restrict, onDelete: Restrict)

  @@id([id, postingId, serialNumber])
  @@map("posting_products")
  @@schema("public")
}

model PrivateApiPostingProducts {
  postingId                  Int      @map("posting_id")
  postingItemId              Int      @map("posting_item_id")
  productId                  Int      @map("product_id")
  cellId                     Int      @map("cell_id")
  cellTitle                  String?  @map("cell_title")
  warehouseId                Int?     @map("warehouse_id")
  code                       String?
  article                    String?
  title                      String?
  uomId                      Int?     @map("uom_id")
  quantity                   Float?
  cost                       Float?
  totalCost                  Float?   @map("total_cost")
  snAccounting               Boolean? @map("sn_accounting")
  sernumsJson                String?  @map("sernums_json")
  warranty                   Int?
  warrantyPeriod             Int?     @map("warranty_period")
  isCustomTaxes              Boolean? @map("is_custom_taxes")
  taxesJson                  String?  @map("taxes_json")
  isEnableExpirationTracking Boolean? @map("is_enable_expiration_tracking")
  isExpiringSoonAlertEnabled Boolean? @map("is_expiring_soon_alert_enabled")
  isCriticalAlertEnabled     Boolean? @map("is_critical_alert_enabled")
  expiringSoonAlertValue     Int?     @map("expiring_soon_alert_value")
  criticalAlertValue         Int?     @map("critical_alert_value")
  expiringSoonAlertUnit      Int?     @map("expiring_soon_alert_unit")
  criticalAlertUnit          Int?     @map("critical_alert_unit")

  serialNumber String @default("") @map("serial_number")
  posting      Posting  @relation(fields: [postingId], references: [id])
  @@id([postingId, postingItemId, serialNumber])
  @@map("posting_products")
  @@schema("private_api")
}

model Cashbox {
  id                       Int      @id
  title                    String?
  type                     Int?
  currencyName             String?  @map("currency_name")
  currencyCode             String?  @map("currency_code")
  balance                  Float?
  isGlobal                 Boolean? @map("is_global")
  isEnabled                Boolean  @default(true) @map("is_enabled")
  lastTransactionCreatedAt BigInt?  @map("last_transaction_created_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  transactions             CashboxTransaction[]

  @@map("cashboxes")
  @@schema("public")
}

model CashboxTransaction {
  id                    Int      @id
  cashboxId             Int      @map("cashbox_id")
  value                 Float
  direction             Int
  employeeId            Int?     @map("employee_id")
  createdAt             BigInt   @map("created_at")
  description           String?
  clientId              Int?     @map("client_id")
  relatedDocumentId     Int?     @map("related_document_id")
  relatedDocumentType   Int?     @map("related_document_type")
  cashflowItemId        Int?     @map("cashflow_item_id")
  cashflowItemName      String?  @map("cashflow_item_name")
  cashflowItemDirection Int?     @map("cashflow_item_direction")
  cashbox               Cashbox  @relation(fields: [cashboxId], references: [id])

  @@index([cashboxId, createdAt])
  @@map("cashbox_transactions")
  @@schema("public")
}

model Refund {
  id                  Int      @id
  number              String
  branchId            Int      @map("branch_id")
  createdAt           DateTime @map("created_at")
  createdById         Int      @map("created_by_id")
  clientId            Int?     @map("client_id")
  clientName          String?  @map("client_name")
  comment             String?
  relatedDocumentId   Int?     @map("related_document_id")
  relatedDocumentType String?  @map("related_document_type")
  total               Float

  @@map("refunds")
  @@schema("public")
}

model Product {
  id                             Int      @id
  code                           String?
  title                          String
  isSerial                       Boolean  @default(false) @map("is_serial")
  article                        String?
  description                    String?
  isEnableExpirationTracking     Boolean? @map("is_enable_expiration_tracking")
  isExpirationTrackingEnabled    Boolean? @map("is_expiration_tracking_enabled")
  isExpiringSoonAlertEnabled     Boolean? @map("is_expiring_soon_alert_enabled")
  isCriticalAlertEnabled         Boolean? @map("is_critical_alert_enabled")
  defaultSupplierId              Int?     @map("default_supplier_id")
  categoryId                     Int?     @map("category_id")
  categoryTitle                  String?  @map("category_title")
  uomId                          Int?     @map("uom_id")
  warranty                       Int?
  warrantyPeriod                 Int?     @map("warranty_period")
  prices                         Json?
  images                         Json?
  customFields                   Json?    @map("custom_fields")
  isDimensionsWeightEnabled      Boolean? @map("is_dimensions_weight_enabled")

  postingProducts                PostingProduct[]

  @@map("products")
  @@schema("public")
}

model Uom {
  id          Int      @id
  description String?
  title       String?
  uomType     String?  @map("uom_type")
  isImperial  Boolean? @map("is_imperial")
  isSystem    Boolean? @map("is_system")
  entityTypes String[] @map("entity_types")

  @@map("uoms")
  @@schema("public")
}

model Employee {
  id          Int     @id
  email       String?
  firstName   String? @map("first_name")
  lastName    String? @map("last_name")
  notes       String?
  phone       String?
  deleted     Boolean
  position    String?
  createdAt   BigInt  @map("created_at")
  startedWork BigInt  @map("started_work")
  avatar      String?

  @@map("employees")
  @@schema("public")
}

model Asset {
  id           Int     @id
  uid          String
  title        String?
  color        String?
  state        String?
  cost         Int?
  group        String?
  brand        String?
  model        String?
  modification String?
  description  String?
  year         String?
  regNumber    String  @map("reg_number")
  ownerName    String? @map("owner_name")
  warehouse    Json
  address      String?
  image        String?
  customFields Json    @map("custom_fields")

  @@map("assets")
  @@schema("public")
}

model Order {
  id               Int      @id
  modifiedAt       BigInt   @map("modified_at")
  uuid             String?
  createdAt        BigInt   @map("created_at")
  doneAt           BigInt?  @map("done_at")
  scheduledFor     BigInt?  @map("scheduled_for")
  duration         Int?
  kindofGood       String?  @map("kindof_good")
  serial           String?
  packagelist      String?
  appearance       String?
  malfunction      String?
  managerNotes     String?  @map("manager_notes")
  engineerNotes   String?  @map("engineer_notes")
  resume           String?
  payed            Float?
  missedPayments   Int?     @map("missed_payments")
  warrantyMeasures Int?     @map("warranty_measures")
  warrantyDate     BigInt?  @map("warranty_date")
  urgent           Boolean?
  discountSum      Float?   @map("discount_sum")
  customFields     String?  @map("custom_fields")
  estimatedCost    String?  @map("estimated_cost")
  closedAt         BigInt?  @map("closed_at")
  estimatedDoneAt  BigInt?  @map("estimated_done_at")
  idLabel          String?  @map("id_label")
  price            Float?
  branchId         Int?     @map("branch_id")
  overdue          Boolean?
  statusOverdue    Boolean? @map("status_overdue")
  managerId        Int?     @map("manager_id")
  engineerId       Int?     @map("engineer_id")
  createdById      Int?     @map("created_by_id")
  closedById       Int?     @map("closed_by_id")
  brand            String?
  model            String?
  clientId         Int?     @map("client_id")
  clientName       String?  @map("client_name")
  assetId          Int?     @map("asset_id")
  assetUid         String?  @map("asset_uid")
  orderTypeId      Int?     @map("order_type_id")
  statusId         Int?     @map("status_id")
  adCampaignId     Int?     @map("ad_campaign_id")

  parts         OrderPart[]
  operations    OrderOperation[]
  attachments   OrderAttachment[]
  resourceLinks OrderToResource[]

  @@index([modifiedAt])
  @@map("orders")
  @@schema("public")
}

model OrderPart {
  orderId        Int     @map("order_id")
  id             Int
  entityId       Int?    @map("entity_id")
  engineerId     Int?    @map("engineer_id")
  title          String?
  amount         Float
  price          Float?
  cost           Float?
  discountValue  Float?  @map("discount_value")
  code           String?
  article        String?
  warranty       Int?
  warrantyPeriod Int?    @map("warranty_period")
  uomId          Int?    @map("uom_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([orderId, id])
  @@map("orders_parts")
  @@schema("public")
}

model OrderOperation {
  orderId        Int    @map("order_id")
  id             Int
  entityId       Int    @map("entity_id")
  engineerId     Int    @map("engineer_id")
  title          String
  amount         Float
  price          Float
  cost           Float
  discountValue  Float  @map("discount_value")
  warranty       Int
  warrantyPeriod Int    @map("warranty_period")
  uomId          Int    @map("uom_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([orderId, id])
  @@map("orders_operations")
  @@schema("public")
}

model OrderAttachment {
  id          Int    @id @default(autoincrement())
  orderId     Int    @map("order_id")
  createdAt   BigInt @map("created_at")
  createdById Int    @map("created_by_id")
  filename    String
  url         String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("orders_attachments")
  @@schema("public")
}

model OrderResource {
  id   Int    @id
  name String

  links OrderToResource[]

  @@map("orders_resources")
  @@schema("public")
}

model OrderToResource {
  resourceId Int @map("resource_id")
  orderId    Int @map("order_id")

  resource OrderResource @relation(fields: [resourceId], references: [id])
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([resourceId, orderId])
  @@map("orders_to_resources")
  @@schema("public")
}