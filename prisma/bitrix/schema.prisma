generator client {
  provider        = "prisma-client-js"
  output          = "../../node_modules/@prisma/client-bitrix"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL_BITRIX")
  schemas      = ["public"]
  relationMode = "prisma"
}

model InsuranceInvoice {
  id           Int       @id
  paymentDate  DateTime? @map("payment_date") @db.Date
  createdAt    DateTime? @map("created_at") @db.Date
  sum          Float?
  autoParkId   String?   @map("auto_park_id")
  autoParkName String?   @map("auto_park_name")
  licensePlate String?   @map("license_plate")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("insurance_invoices")
  @@schema("public")
}

model SyncMetadata {
  entityName String   @id @map("entity_name")
  lastSyncAt DateTime @map("last_sync_at")

  @@map("sync_metadata")
  @@schema("public")
}
