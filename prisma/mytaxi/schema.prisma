generator client {
  provider        = "prisma-client-js"
  output          = "../../node_modules/@prisma/client-mytaxi"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL_MYTAXI")
  schemas      = ["public"]
  relationMode = "prisma"
}

enum CarEventType {
  BUSY_WITH_PRIVATE_TRADER
  RENTAL
  ON_SERVICE_STATION
  BUSY_WITH_CREW
  ROAD_ACCIDENT
  OTHER
  AUTO_POUND

  @@map("car_event_type")
  @@schema("public")
}

model Car {
  id           String       @id
  status       CarEventType
  licensePlate String       @map("license_plate")
  autoParkId   String       @map("auto_park_id")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@index([licensePlate])
  @@index([autoParkId])
  @@map("cars")
  @@schema("public")
}

model CarStatusLog {
  id                BigInt        @id @default(autoincrement())
  carId             String        @map("car_id")
  prevStatus        CarEventType? @map("prev_status")
  nextStatus        CarEventType  @map("next_status")
  isManagerNotified Boolean       @default(false) @map("is_manager_notified")
  changedAt         DateTime      @default(now()) @map("changed_at")

  @@index([carId, changedAt])
  @@index([changedAt])
  @@map("car_status_log")
  @@schema("public")
}
