generator client {
  provider        = "prisma-client-js"
  output          = "../../node_modules/@prisma/client-mytaxi"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL_MYTAXI")
  schemas      = ["public"]
  relationMode = "prisma"
}

enum CarEventType {
  BUSY_WITH_PRIVATE_TRADER
  RENTAL
  ON_SERVICE_STATION
  BUSY_WITH_CREW
  ROAD_ACCIDENT
  OTHER
  AUTO_POUND

  @@map("car_event_type")
  @@schema("public")
}

model AutoPark {
  id          String   @id
  companyId   String   @map("company_id")
  name        String
  timezone    String
  currencyId  String   @map("currency_id")
  countryCode String   @map("country_code")
  code        String
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  cars Car[]

  @@index([companyId])
  @@map("auto_parks")
  @@schema("public")
}

model Car {
  id           String       @id
  status       CarEventType
  licensePlate String       @map("license_plate")
  autoParkId   String       @map("auto_park_id")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  autoPark   AutoPark       @relation(fields: [autoParkId], references: [id])
  statusLogs CarStatusLog[]

  @@index([status])
  @@index([licensePlate])
  @@index([autoParkId])
  @@map("cars")
  @@schema("public")
}

model CarStatusLog {
  id                BigInt        @id @default(autoincrement())
  carId             String        @map("car_id")
  prevStatus        CarEventType? @map("prev_status")
  nextStatus        CarEventType  @map("next_status")
  isManagerNotified Boolean       @default(false) @map("is_manager_notified")
  changedAt         DateTime      @default(now()) @map("changed_at")

  car Car @relation(fields: [carId], references: [id])

  @@index([carId, changedAt])
  @@index([changedAt])
  @@map("car_status_log")
  @@schema("public")
}
